root = true

# ─── Default for all files ────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 4
insert_final_newline     = true
trim_trailing_whitespace = true
max_line_length          = 120

# ─── PHP (PSR-12) ─────────────────────────────────────────────────────────────
[*.php]
indent_style = space
indent_size  = 4

# ─── Blade templates ──────────────────────────────────────────────────────────
[*.blade.php]
indent_style = space
indent_size  = 4

# ─── JavaScript / TypeScript ──────────────────────────────────────────────────
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size  = 2

# ─── JSON ─────────────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2

# ─── YAML ─────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ─── CSS / SCSS ───────────────────────────────────────────────────────────────
[*.{css,scss}]
indent_style = space
indent_size  = 2

# ─── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false

# ─── Makefile (requires tabs) ─────────────────────────────────────────────────
[Makefile]
indent_style = tab
